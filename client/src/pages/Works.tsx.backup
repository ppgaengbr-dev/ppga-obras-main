import { useState, useEffect } from 'react';
import { Card } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter } from '@/components/ui/dialog';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from '@/components/ui/select';
import { toast } from 'sonner';
import { Edit2, Calendar, ChevronDown } from 'lucide-react';

const WORK_STATUSES = [
  { value: 'waiting', label: 'Aguardando' },
  { value: 'in_progress', label: 'Em andamento' },
  { value: 'interrupted', label: 'Interrompido' },
  { value: 'completed', label: 'Finalizado' },
];

// Helper para abrir seletor de data
const openDatePicker = (inputId: string) => {
  const input = document.getElementById(inputId) as HTMLInputElement;
  if (!input) return;
  
  input.focus();
  
  // Tentar showPicker() para Chrome moderno
  if (typeof (input as any).showPicker === 'function') {
    try {
      (input as any).showPicker();
      return;
    } catch (e) {
      // Fallback se showPicker falhar
    }
  }
  
  // Fallback: click() para outros navegadores
  input.click();
};

// Formatadores
const formatCurrency = (value: string) => {
  const cleaned = value.replace(/\D/g, '');
  const number = parseInt(cleaned || '0', 10);
  return new Intl.NumberFormat('pt-BR', {
    style: 'currency',
    currency: 'BRL',
  }).format(number / 100);
};

// Dados de teste para Obras
const TEST_WORKS = [
  {
    id: 1,
    name: 'Obra 01',
    workName: 'Casa Moderna',
    clientName: 'João Silva',
    status: 'waiting',
    workValue: 'R$ 150.000,00',
    startDate: '01/03/2026',
    endDate: '30/06/2026',
    responsible: 'Renato Araújo',
    // Dados do cliente
    clientPhone: '(11) 98765-4321',
    clientBirthDate: '15/05/1990',
    clientAddress: 'Rua A, 123',
    clientOrigin: 'google',
    clientContact: 'Google',
    clientArchitect: 'Arquiteto 01',
  },
];

export default function Works() {
  // Carregar dados do localStorage ou usar dados de teste
  const [works, setWorks] = useState(() => {
    const saved = localStorage.getItem('ppga_works');
    return saved ? JSON.parse(saved) : TEST_WORKS;
  });
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [editingWork, setEditingWork] = useState<(typeof TEST_WORKS)[0] | null>(null);
  const [showDetails, setShowDetails] = useState(false);

  const [formData, setFormData] = useState({
    workName: '',
    clientName: '',
    status: 'waiting',
    workValue: '',
    startDate: '',
    endDate: '',
    responsible: '',
  });

  // Salvar obras no localStorage quando mudar
  useEffect(() => {
    localStorage.setItem('ppga_works', JSON.stringify(works));
  }, [works]);

  // Listen for custom event from header button
  useEffect(() => {
    const handleOpenAddModal = () => {
      openAddModal();
    };
    window.addEventListener('openAddWorkModal', handleOpenAddModal);
    return () => {
      window.removeEventListener('openAddWorkModal', handleOpenAddModal);
    };
  }, []);

  const openAddModal = () => {
    setEditingWork(null);
    setShowDetails(false);
    setFormData({
      workName: '',
      clientName: '',
      status: 'waiting',
      workValue: '',
      startDate: '',
      endDate: '',
      responsible: '',
    });
    setIsModalOpen(true);
  };

  const openEditModal = (work: (typeof TEST_WORKS)[0]) => {
    setEditingWork(work);
    setShowDetails(false);
    setFormData({
      workName: work.workName,
      clientName: work.clientName,
      status: work.status,
      workValue: work.workValue,
      startDate: work.startDate,
      endDate: work.endDate,
      responsible: work.responsible,
    });
    setIsModalOpen(true);
  };

  const handleSave = () => {
    if (!formData.workName.trim()) {
      toast.error('Nome da obra é obrigatório');
      return;
    }
    if (!formData.clientName.trim()) {
      toast.error('Nome do cliente é obrigatório');
      return;
    }
    if (!formData.status) {
      toast.error('Status é obrigatório');
      return;
    }
    if (!formData.workValue.trim()) {
      toast.error('Valor da obra é obrigatório');
      return;
    }
    if (!formData.startDate.trim()) {
      toast.error('Data de início é obrigatória');
      return;
    }
    if (!formData.endDate.trim()) {
      toast.error('Data de término é obrigatória');
      return;
    }
    if (!formData.responsible.trim()) {
      toast.error('Responsável é obrigatório');
      return;
    }

    if (editingWork) {
      setWorks(works.map(w => w.id === editingWork.id ? { ...w, ...formData } : w));
      toast.success('Obra atualizada com sucesso!');
    } else {
      const newWork = {
        id: Math.max(...works.map(w => w.id), 0) + 1,
        name: `Obra ${Math.max(...works.map(w => w.id), 0) + 1}`,
        ...formData,
        clientPhone: '',
        clientBirthDate: '',
        clientAddress: '',
        clientOrigin: '',
        clientContact: '',
        clientArchitect: '',
      };
      setWorks([...works, newWork]);
      toast.success('Obra criada com sucesso!');
    }

    setIsModalOpen(false);
  };

  const handleDeleteWork = (id: number) => {
    setWorks(works.filter(w => w.id !== id));
    toast.success('Obra removida com sucesso!');
  };

  // Agrupar obras por status
  const groupedWorks = {
    waiting: works.filter(w => w.status === 'waiting'),
    in_progress: works.filter(w => w.status === 'in_progress'),
    interrupted: works.filter(w => w.status === 'interrupted'),
    completed: works.filter(w => w.status === 'completed'),
  };

  return (
    <>
      <div className="grid grid-cols-4 gap-6">
        {Object.entries(groupedWorks).map(([status, statusWorks]) => (
          <div key={status}>
            <h2 className="font-semibold text-gray-900 mb-4">
              {status === 'waiting' && `Aguardando (${statusWorks.length})`}
              {status === 'in_progress' && `Em andamento (${statusWorks.length})`}
              {status === 'interrupted' && `Interrompido (${statusWorks.length})`}
              {status === 'completed' && `Finalizado (${statusWorks.length})`}
            </h2>

            <div className="space-y-3">
              {statusWorks.map((work) => (
                <div key={work.id}>
                  <Card className="p-4 cursor-pointer hover:shadow-md transition-shadow relative">
                    {/* Ações do Card - Lado a lado */}
                    <div className="absolute top-3 right-3 flex items-center gap-2">
                      <button
                        onClick={() => openEditModal(work)}
                        title="Editar obra"
                        className="text-gray-400 hover:text-gray-600 flex-shrink-0"
                      >
                        <Edit2 size={16} />
                      </button>
                    </div>

                    {/* Conteúdo do Card */}
                    <div className="flex flex-col pr-6">
                      {/* Nome da Obra - Título Principal */}
                      <p className="font-semibold text-gray-900 text-sm">
                        {work.workName}
                      </p>

                      {/* Cliente - Subtítulo */}
                      <p className="text-gray-600 text-xs mt-1">
                        {work.clientName}
                      </p>

                      {/* Responsável - Subtítulo */}
                      <p className="text-gray-500 text-xs mt-1">
                        {work.responsible}
                      </p>

                      {/* Valor - Subtítulo */}
                      <p className="text-gray-500 text-xs mt-1">
                        {work.workValue}
                      </p>
                    </div>
                  </Card>
                </div>
              ))}

              {statusWorks.length === 0 && (
                <Card className="p-4 text-center text-gray-400 text-sm">
                  Nenhuma obra
                </Card>
              )}
            </div>
          </div>
        ))}
      </div>

      {/* Modal */}
      <Dialog open={isModalOpen} onOpenChange={setIsModalOpen}>
        <DialogContent className="max-w-2xl">
          <DialogHeader>
            <DialogTitle>
              {editingWork ? 'Editar obra' : 'Nova obra'}
            </DialogTitle>
          </DialogHeader>

          <div className="space-y-5 py-4">
            {/* Linha 1: Nome da obra | Cliente */}
            <div className="grid grid-cols-2 gap-4">
              <div>
                <Label htmlFor="workName" className="text-sm font-medium mb-2 block">Nome da obra *</Label>
                <Input
                  id="workName"
                  placeholder="Digite o nome da obra"
                  value={formData.workName}
                  onChange={(e) => setFormData({ ...formData, workName: e.target.value })}
                  className="w-full bg-white border border-gray-300"
                />
              </div>
              <div>
                <Label htmlFor="clientName" className="text-sm font-medium mb-2 block">Cliente *</Label>
                <Input
                  id="clientName"
                  placeholder="Digite o nome do cliente"
                  value={formData.clientName}
                  onChange={(e) => setFormData({ ...formData, clientName: e.target.value })}
                  className="w-full bg-white border border-gray-300"
                />
              </div>
            </div>

            {/* Linha 2: Status | Valor da obra */}
            <div className="grid grid-cols-2 gap-4">
              <div>
                <Label htmlFor="status" className="text-sm font-medium mb-2 block">Status *</Label>
                <Select value={formData.status} onValueChange={(value) => setFormData({ ...formData, status: value })}>
                  <SelectTrigger id="status" className="w-full bg-white border border-gray-300">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    {WORK_STATUSES.map((s) => (
                      <SelectItem key={s.value} value={s.value}>
                        {s.label}
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
              <div>
                <Label htmlFor="workValue" className="text-sm font-medium mb-2 block">Valor total da obra *</Label>
                <Input
                  id="workValue"
                  placeholder="R$ 0,00"
                  value={formData.workValue}
                  onChange={(e) => setFormData({ ...formData, workValue: formatCurrency(e.target.value) })}
                  className="w-full bg-white border border-gray-300"
                />
              </div>
            </div>

            {/* Linha 3: Data de início | Data de término */}
            <div className="grid grid-cols-2 gap-4">
              <div>
                <Label htmlFor="startDate" className="text-sm font-medium mb-2 block">Data de início *</Label>
                <div className="relative">
                  <Input
                    id="startDate"
                    type="date"
                    value={formData.startDate}
                    onChange={(e) => setFormData({ ...formData, startDate: e.target.value })}
                    className="w-full bg-white border border-gray-300"
                  />
                  <button
                    type="button"
                    onClick={() => openDatePicker('startDate')}
                    className="absolute right-3 top-3 text-gray-400 hover:text-gray-600 pointer-events-auto"
                  >
                    <Calendar size={16} />
                  </button>
                </div>
              </div>
              <div>
                <Label htmlFor="endDate" className="text-sm font-medium mb-2 block">Data de término *</Label>
                <div className="relative">
                  <Input
                    id="endDate"
                    type="date"
                    value={formData.endDate}
                    onChange={(e) => setFormData({ ...formData, endDate: e.target.value })}
                    className="w-full bg-white border border-gray-300"
                  />
                  <button
                    type="button"
                    onClick={() => openDatePicker('endDate')}
                    className="absolute right-3 top-3 text-gray-400 hover:text-gray-600 pointer-events-auto"
                  >
                    <Calendar size={16} />
                  </button>
                </div>
              </div>
            </div>

            {/* Linha 4: Responsável (linha inteira) */}
            <div>
              <Label htmlFor="responsible" className="text-sm font-medium mb-2 block">Responsável *</Label>
              <Input
                id="responsible"
                placeholder="Digite o nome do responsável"
                value={formData.responsible}
                onChange={(e) => setFormData({ ...formData, responsible: e.target.value })}
                className="w-full bg-white border border-gray-300"
              />
            </div>

            {/* Toggle Mostrar detalhes */}
            <div className="flex items-center gap-2 pt-2">
              <button
                type="button"
                onClick={() => setShowDetails(!showDetails)}
                className="text-sm text-blue-600 hover:text-blue-800 font-medium"
              >
                {showDetails ? '✓ Mostrar detalhes' : 'Mostrar detalhes'}
              </button>
            </div>

            {/* Seção Detalhes do cliente (colapsável) */}
            {showDetails && editingWork && (
              <div className="border-t pt-4 mt-4">
                <h3 className="text-sm font-semibold text-gray-900 mb-4">Detalhes do cliente</h3>
                
                {/* Linha 1: Nome completo | Telefone */}
                <div className="grid grid-cols-2 gap-4 mb-4">
                  <div>
                    <Label className="text-sm font-medium mb-2 block">Nome completo</Label>
                    <Input
                      disabled
                      value={editingWork.clientName}
                      className="w-full bg-gray-100 border border-gray-300 text-gray-600"
                    />
                  </div>
                  <div>
                    <Label className="text-sm font-medium mb-2 block">Telefone</Label>
                    <Input
                      disabled
                      value={editingWork.clientPhone}
                      className="w-full bg-gray-100 border border-gray-300 text-gray-600"
                    />
                  </div>
                </div>

                {/* Linha 2: Data de nascimento | Endereço */}
                <div className="grid grid-cols-2 gap-4 mb-4">
                  <div>
                    <Label className="text-sm font-medium mb-2 block">Data de nascimento</Label>
                    <Input
                      disabled
                      value={editingWork.clientBirthDate}
                      className="w-full bg-gray-100 border border-gray-300 text-gray-600"
                    />
                  </div>
                  <div>
                    <Label className="text-sm font-medium mb-2 block">Endereço completo</Label>
                    <Input
                      disabled
                      value={editingWork.clientAddress}
                      className="w-full bg-gray-100 border border-gray-300 text-gray-600"
                    />
                  </div>
                </div>

                {/* Linha 3: Origem | Contato */}
                <div className="grid grid-cols-2 gap-4 mb-4">
                  <div>
                    <Label className="text-sm font-medium mb-2 block">Origem</Label>
                    <Input
                      disabled
                      value={editingWork.clientOrigin}
                      className="w-full bg-gray-100 border border-gray-300 text-gray-600"
                    />
                  </div>
                  <div>
                    <Label className="text-sm font-medium mb-2 block">Contato</Label>
                    <Input
                      disabled
                      value={editingWork.clientContact}
                      className="w-full bg-gray-100 border border-gray-300 text-gray-600"
                    />
                  </div>
                </div>

                {/* Linha 4: Responsável | Arquiteto */}
                <div className="grid grid-cols-2 gap-4">
                  <div>
                    <Label className="text-sm font-medium mb-2 block">Responsável</Label>
                    <Input
                      disabled
                      value={editingWork.responsible}
                      className="w-full bg-gray-100 border border-gray-300 text-gray-600"
                    />
                  </div>
                  <div>
                    <Label className="text-sm font-medium mb-2 block">Arquiteto</Label>
                    <Input
                      disabled
                      value={editingWork.clientArchitect}
                      className="w-full bg-gray-100 border border-gray-300 text-gray-600"
                    />
                  </div>
                </div>
              </div>
            )}
          </div>

          {/* Rodapé do Modal */}
          <DialogFooter className="flex justify-end gap-3 mt-6">
            <Button variant="outline" onClick={() => setIsModalOpen(false)}>
              Cancelar
            </Button>
            <Button onClick={handleSave} className="bg-gray-900 hover:bg-gray-800 text-white">
              {editingWork ? 'Salvar' : 'Adicionar'}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </>
  );
}
